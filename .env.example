# ---- Supabase ----
# Found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key — server-side only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Pipedrive ----
# Pipedrive Settings → Personal Preferences → API
PIPEDRIVE_API_TOKEN=your-40-char-token-here
# The XXX in https://XXX.pipedrive.com (e.g. "asapcreditrepair")
PIPEDRIVE_COMPANY_DOMAIN=your-company-domain

# ---- App auth ----
# Simple shared-password gate for the internal tool.
# Pick a strong random string; everyone who uses the app needs it.
APP_PASSWORD=change-me-to-something-strong

# ---- Cron auth (optional) ----
# If set, the /api/cron-trigger fallback endpoint will require this header.
# Not needed for Netlify scheduled functions (those run server-side).
CRON_SECRET=optional-extra-secret
